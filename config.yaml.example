# Device-specific configuration
device_name: "Windows Desktop"

# Root directory to scan for projects (directories with .git)
# Windows:    "C:\\Users\\you\\Projects"
# macOS:      "/Users/you/Projects"
# Linux:      "/home/you/Projects"
# Docker:     "/projects" (mounted from host)
projects_root: "C:\\Users\\you\\Projects"

# Copilot CLI executable
# Usually just "copilot" if it's on your PATH.
# Windows: you may need the full path, e.g. "C:\\nvm4w\\nodejs\\copilot.cmd"
copilot_command: "copilot"

# Timeout in seconds for copilot CLI invocations (default: 3 hours)
copilot_timeout: 10800
