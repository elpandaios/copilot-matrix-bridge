# Matrix homeserver URL
MATRIX_HOMESERVER=https://matrix.example.com

# Bot credentials (create one user per device: copilot-win, copilot-mac, etc.)
MATRIX_BOT_USER=@copilot-win:example.com
MATRIX_BOT_PASSWORD=your-bot-password-here

# Your Matrix user ID (only messages from this user are processed)
MATRIX_OWNER_ID=@you:example.com
